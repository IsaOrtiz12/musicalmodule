import pandas as pd
import numpy as np
from sklearn.metrics.pairwise import cosine_similarity
import matplotlib.pyplot as plt
import os

os.chdir("/Users/isabelle/Downloads/Analyses")

df = pd.read_csv("dataset.csv")

# Clean up
df = df.dropna().drop_duplicates(subset=["track_name", "artists"])

# Features for similarity
features = ["danceability", "energy", "loudness", "speechiness",
            "acousticness", "instrumentalness", "liveness", "valence", "tempo"]

# Normalize to 0-1 scale
df_scaled = df.copy()
for f in features:
    df_scaled[f] = (df[f] - df[f].min()) / (df[f].max() - df[f].min())

# Feature matrix
X = df_scaled[features].values

# Query songs
queries = ["Blinding Lights", "bad guy", "Stay With Me"]

def get_top10_similar(query_name, data, X, features):
    # Find query row
    matches = data[data["track_name"].str.lower() == query_name.lower()]
    
    if matches.empty:
        print(f"Song not found: {query_name}")
        return None
    
    query_index = matches.index[0]
    query_vec = X[data.index.get_loc(query_index)].reshape(1, -1)
    
    # Cosine similarity
    similarities = cosine_similarity(query_vec, X)[0]
    
    # Attach to dataframe
    results = data[["track_name", "artists"]].copy()
    results["similarity"] = similarities
    
    # Remove the query song itself and sort
    results = results[results["track_name"].str.lower() != query_name.lower()]
    results = results.sort_values("similarity", ascending=False).head(10)
    
    return results

# Run and print results + save figures
for q in queries:
    print(f"Top 10 Songs Similar to: {q}")
    
    result = get_top10_similar(q, df_scaled, X, features)
    
    if result is not None:
        print(result[["track_name", "artists", "similarity"]].to_string(index=False))
        
        # Save bar chart
        plt.figure(figsize=(10, 5))
        plt.barh(result["track_name"], result["similarity"], color="steelblue")
        plt.xlabel("Cosine Similarity")
        plt.title(f"Top 10 Songs Similar to: {q}")
        plt.tight_layout()
        plt.savefig(f"similar_to_{q.replace(' ', '_')}.png")
        plt.show()
